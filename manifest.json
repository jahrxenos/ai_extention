{
  "manifest_version": 2,
  "name": "Адаптация текста",
  "version": "0.0.3",
  "description": "Адаптирует сложность текста на любой веб-странице с помощью AI",

  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "browser_action": {
    "default_icon": {
      "48": "icons/icon48.png"
    },
    "default_title": "Адаптация текста"
  },

  "background": {
    "scripts": ["background/background.js"],
    "persistent": true
  },

  "permissions": [
    "activeTab",
    "storage",
    "contextMenus"
  ],

  "options_ui": {
    "page": "options/options.html",
    "browser_style": false
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "text-adapter@dev.local",
      "strict_min_version": "91.0"
    }
  }
}
